# Persona — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env before running docker compose up.
# This is the ONLY file you need to edit for a standard setup.
#
# All other configuration (AD connection, local admin account)
# is done through the Setup Wizard in the browser.
#
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────

# JWT Secret — signs login session tokens
# Generate a secure value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Or on Linux/Mac:
#   openssl rand -hex 32
JWT_SECRET=replace-this-with-a-generated-secret

# How long login sessions last (in minutes)
# Default: 480 = 8 hours (a full work day)
JWT_EXPIRE_MINUTES=480

# Port Persona listens on
# Change this if port 8000 is in use on your host
APP_PORT=8000

# CORS allowed origins (JSON array format — pydantic-settings v2)
CORS_ORIGINS=["http://localhost:5173"]

# Frontend Vite port (dev only)
FRONTEND_PORT=5173

# Data directory inside the container (Docker volume mount point)
DATA_DIR=/app/data

